# Database
DATABASE_URL=postgresql+psycopg://semantic:semantic@localhost:5432/semantic_reasoning

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Object Storage (MinIO — falls back to Postgres blobs when unavailable)
OBJECT_STORE_BACKEND=postgres
OBJECT_STORE_BUCKET=semantic-artifacts
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Vector Store (Qdrant — falls back to token-count in-process when unavailable)
VECTOR_STORE_BACKEND=postgres
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks

# Neo4j
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=semantic-neo4j

# API Keys
ANTHROPIC_API_KEY=sk
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
