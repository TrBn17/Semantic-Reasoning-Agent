# Postgres bootstrap (used by docker compose postgres service)
POSTGRES_DB=semantic_reasoning
POSTGRES_USER=semantic
POSTGRES_PASSWORD=semantic
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PUBLISHED_PORT=5432

# App / API
APP_ENV=development
APP_NAME=Semantic Reasoning Agent
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
DATABASE_ECHO=false
UVICORN_RELOAD=false

# Database URLs
# - DATABASE_URL: used by local API/worker process running on host machine
# - DATABASE_URL_DOCKER: used by API/worker containers in docker compose (host = postgres)
DATABASE_URL=postgresql+psycopg://semantic:semantic@localhost:5432/semantic_reasoning
DATABASE_URL_DOCKER=postgresql+psycopg://semantic:semantic@postgres:5432/semantic_reasoning

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BROKER_URL_DOCKER=redis://redis:6379/0
CELERY_RESULT_BACKEND_DOCKER=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false

# Neo4j
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_URI_DOCKER=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=semantic-neo4j
NEO4J_DATABASE=neo4j

# Identity / model defaults
DEFAULT_WORKSPACE_ID=workspace-demo
DEFAULT_WORKSPACE_NAME=Demo Workspace
DEFAULT_USER_ID=user-demo
DEFAULT_USER_EMAIL=demo@example.com
DEFAULT_USER_NAME=Demo User
DEFAULT_PROVIDER=echo
DEFAULT_MODEL=local-echo

# Provider keys
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL_DOCKER=http://host.docker.internal:11434

# Ontology extraction
ONTOLOGY_LLM_PROVIDER=anthropic
ONTOLOGY_LLM_MODEL=claude-sonnet-4-5
ONTOLOGY_PROMPT_VERSION=v1
ONTOLOGY_CHUNK_LIMIT=24
ONTOLOGY_LLM_ENABLED=true

# Object Storage (MinIO)
OBJECT_STORE_BACKEND=postgres
OBJECT_STORE_BUCKET=semantic-artifacts
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_ENDPOINT_DOCKER=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Vector Store (Qdrant)
VECTOR_STORE_BACKEND=postgres
QDRANT_URL=http://localhost:6333
QDRANT_URL_DOCKER=http://qdrant:6333
